{
  "name": "@pokepets/api-contracts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./app": {
      "types": "./src/app.ts",
      "default": "./dist/app.js"
    },
    "./common": {
      "types": "./src/common.ts",
      "default": "./dist/common.js"
    },
    "./integrations": {
      "types": "./src/integrations.ts",
      "default": "./dist/integrations.js"
    },
    "./jobs": {
      "types": "./src/jobs.ts",
      "default": "./dist/jobs.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "openapi": "node --experimental-strip-types scripts/generate-openapi.ts"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
