{
  "name": "@tma-game/db-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generated Supabase database types for tmaGame.",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "tsc -b tsconfig.json --clean"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
