{
  "name": "@tma-game/validation",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod validation schemas for the Telegram Mini App blind-box card game.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./common": {
      "types": "./dist/common.schemas.d.ts",
      "import": "./dist/common.schemas.js"
    },
    "./auth": {
      "types": "./dist/auth.schemas.d.ts",
      "import": "./dist/auth.schemas.js"
    },
    "./me": {
      "types": "./dist/me.schemas.d.ts",
      "import": "./dist/me.schemas.js"
    },
    "./box": {
      "types": "./dist/box.schemas.d.ts",
      "import": "./dist/box.schemas.js"
    },
    "./telegram": {
      "types": "./dist/telegram.schemas.d.ts",
      "import": "./dist/telegram.schemas.js"
    },
    "./payment": {
      "types": "./dist/payment.schemas.d.ts",
      "import": "./dist/payment.schemas.js"
    },
    "./market": {
      "types": "./dist/market.schemas.d.ts",
      "import": "./dist/market.schemas.js"
    },
    "./inventory": {
      "types": "./dist/inventory.schemas.d.ts",
      "import": "./dist/inventory.schemas.js"
    },
    "./album": {
      "types": "./dist/album.schemas.d.ts",
      "import": "./dist/album.schemas.js"
    },
    "./task": {
      "types": "./dist/task.schemas.d.ts",
      "import": "./dist/task.schemas.js"
    },
    "./wallet": {
      "types": "./dist/wallet.schemas.d.ts",
      "import": "./dist/wallet.schemas.js"
    },
    "./game": {
      "types": "./dist/game.schemas.d.ts",
      "import": "./dist/game.schemas.js"
    },
    "./admin": {
      "types": "./dist/admin.schemas.d.ts",
      "import": "./dist/admin.schemas.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "build": "tsup src/index.ts src/*.schemas.ts --format esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts src/*.schemas.ts --format esm --dts --watch --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tma-game/domain": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}