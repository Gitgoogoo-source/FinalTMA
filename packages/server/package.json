{
  "name": "@tma-game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Server-only shared utilities for the Telegram Mini App backend.",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "tsc -b tsconfig.json --clean"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "@ton/ton": "catalog:",
    "@tma-game/db-types": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
