{
  "name": "@tma-game/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./currencies": {
      "types": "./dist/currencies.d.ts",
      "default": "./dist/currencies.js"
    },
    "./rarities": {
      "types": "./dist/rarities.d.ts",
      "default": "./dist/rarities.js"
    },
    "./itemTypes": {
      "types": "./dist/itemTypes.d.ts",
      "default": "./dist/itemTypes.js"
    },
    "./statuses": {
      "types": "./dist/statuses.d.ts",
      "default": "./dist/statuses.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "tsc -b tsconfig.json --clean"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
