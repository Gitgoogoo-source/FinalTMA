{
  "$schema": "https://json.schemastore.org/package",
  "name": "pokepets",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PokePets Telegram Mini App",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.x",
    "pnpm": "11.1.3"
  },
  "scripts": {
    "dev": "vercel dev",
    "dev:web": "pnpm --filter @pokepets/web dev",
    "build": "pnpm --filter @pokepets/api-contracts build && pnpm --filter @pokepets/api build && pnpm --filter @pokepets/web build && pnpm typecheck:api",
    "build:web": "pnpm --filter @pokepets/web build",
    "typecheck": "pnpm --filter @pokepets/api-contracts typecheck && pnpm --filter @pokepets/api typecheck && pnpm --filter @pokepets/web typecheck && pnpm --filter @pokepets/ton typecheck && pnpm typecheck:api",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contracts:openapi": "pnpm --filter @pokepets/api-contracts openapi",
    "contracts:check": "python3 tools/contracts/check_openapi.py",
    "db:lint": "supabase db lint --local --schema api,identity,catalog,operations,economy,inventory,gacha,expedition,wheel,market,payments,vip,tasks,referral,album,onchain,risk --level warning --fail-on error",
    "db:migrations:check": "supabase db diff --from migrations --to migrations --use-migra --schema api,identity,catalog,operations,economy,inventory,gacha,expedition,wheel,market,payments,vip,tasks,referral,album,onchain,risk",
    "db:diff:check": "python3 tools/db/check_schema.py",
    "db:diff": "supabase db diff",
    "catalog:build": "python3 tools/catalog/build.py",
    "catalog:pin-assets": "python3 tools/catalog/build.py --pin-assets",
    "catalog:check-assets": "python3 tools/catalog/build.py --check-assets",
    "catalog:check": "python3 tools/catalog/check.py",
    "assets:check:development": "python3 tools/assets/check.py development",
    "assets:check:production": "python3 tools/assets/check.py production",
    "manifest:build": "python3 tools/web/build_manifest.py",
    "manifest:check": "python3 tools/web/check_manifest.py repository",
    "manifest:check:development": "python3 tools/web/check_manifest.py development",
    "manifest:check:production": "python3 tools/web/check_manifest.py production",
    "architecture:check": "python3 tools/architecture/check.py",
    "chain:build": "pnpm --filter @pokepets/ton build",
    "validate:static": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm contracts:check && pnpm catalog:check && pnpm db:migrations:check && pnpm db:lint && pnpm db:diff:check && pnpm architecture:check && pnpm manifest:check && pnpm build && pnpm assets:check:development",
    "deploy:preview": "vercel deploy",
    "deploy:production": "vercel deploy --prod"
  },
  "dependencies": {
    "@pokepets/api": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.7",
    "@vercel/node": "5.7.15",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "supabase": "2.100.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vercel": "54.1.0"
  }
}
