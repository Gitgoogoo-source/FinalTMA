{
  "$schema": "https://json.schemastore.org/package",
  "name": "tma-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram Mini App blind box gacha card game with Supabase, Vercel, Telegram Stars and TON Connect.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.1.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "contracts"
  ],
  "scripts": {
    "dev": "pnpm --filter @tma-game/web dev",
    "dev:web": "pnpm --filter @tma-game/web dev",
    "dev:admin": "pnpm --filter @tma-game/admin dev",
    "dev:vercel": "vercel dev",
    "build": "pnpm -r --if-present build",
    "build:web": "pnpm --filter @tma-game/web build",
    "build:admin": "pnpm --filter @tma-game/admin build",
    "build:packages": "pnpm -r --filter \"./packages/**\" --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "typecheck:root": "pnpm typecheck:api && pnpm typecheck:tests",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "lint": "pnpm -r --if-present lint",
    "lint:root": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:workspaces && pnpm test:e2e",
    "test:workspaces": "pnpm -r --if-present test",
    "test:unit": "vitest run --passWithNoTests",
    "test:unit:watch": "vitest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "test:db": "supabase test db --local supabase/tests/*.test.sql",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:lint": "supabase db lint",
    "db:diff": "supabase db diff --use-migra",
    "db:migration:new": "supabase migration new",
    "db:types:local": "supabase gen types typescript --local --schema core,economy,catalog,gacha,inventory,market,payments,tasks,album,onchain,ops > packages/db-types/src/database.types.ts && prettier --write packages/db-types/src/database.types.ts",
    "db:types:linked": "supabase gen types typescript --linked --schema core,economy,catalog,gacha,inventory,market,payments,tasks,album,onchain,ops > packages/db-types/src/database.types.ts && prettier --write packages/db-types/src/database.types.ts",
    "db:seed": "tsx scripts/seed-dev.ts",
    "db:reconcile": "tsx scripts/reconcile-ledger.ts",
    "contracts:build": "pnpm --filter @tma-game/contracts build",
    "contracts:test": "pnpm --filter @tma-game/contracts test",
    "contracts:deploy:testnet": "pnpm --filter @tma-game/contracts deploy:testnet",
    "contracts:deploy:mainnet": "pnpm --filter @tma-game/contracts deploy:mainnet",
    "ops:create-admin": "tsx scripts/create-admin.ts",
    "ops:rebuild-market-stats": "tsx scripts/rebuild-market-stats.ts",
    "ops:backfill-album": "tsx scripts/backfill-album-progress.ts",
    "ops:rebuild-leaderboard": "tsx scripts/rebuild-leaderboard.ts",
    "ops:retry-payments": "tsx scripts/retry-failed-payments.ts",
    "ops:retry-mints": "tsx scripts/retry-failed-mints.ts",
    "deploy:preview": "vercel",
    "deploy:production": "vercel --prod",
    "security:audit": "pnpm audit --audit-level high",
    "deps:outdated": "pnpm outdated -r",
    "clean": "rimraf node_modules .turbo coverage playwright-report test-results apps/*/dist apps/*/.vite packages/*/dist contracts/dist",
    "doctor": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@vercel/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "supabase": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "8.59.3",
    "vercel": "catalog:",
    "vitest": "catalog:"
  }
}
