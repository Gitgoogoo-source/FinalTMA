# =============================================================================
# tmaGame Environment Example
# =============================================================================
# 不要把真实密钥提交到 Git。
# 生产环境密钥应放在 Vercel Environment Variables / Supabase Secrets 中。
# 所有 VITE_ 开头的变量会暴露给浏览器；不要把 Bot Token、service role key、
# 私钥、session secret、webhook secret 写成 VITE_。
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
APP_NAME=tmaGame
APP_VERSION=0.1.0
APP_TIMEZONE=UTC
LOG_LEVEL=debug

# 本地开发地址
APP_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
API_BASE_URL=http://localhost:3000/api
PUBLIC_APP_URL=http://localhost:5173

# 浏览器可见变量
VITE_APP_NAME=tmaGame
VITE_TMA_ENV=development
VITE_PUBLIC_BASE_URL=http://localhost:5173
# 本地验收时页面地址必须和 VITE_API_BASE_URL 的主机名一致。
# 如果这里使用 localhost，就用 http://localhost:3000 打开页面，不要混用 127.0.0.1。
VITE_API_BASE_URL=http://localhost:3000/api
VITE_TG_BOT_USERNAME=replace_with_bot_username_without_at
VITE_TONCONNECT_MANIFEST_URL=http://localhost:5173/tonconnect-manifest.json
# 前端钱包入口公开开关；只影响 UI，后端仍必须独立校验钱包 / Mint 能力。
VITE_ENABLE_TON_CONNECT=true

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
VERCEL_ENV=development
VERCEL_URL=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
VERCEL_TOKEN=

# Vercel server-only env checklist:
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_WEBHOOK_SECRET
# - SUPABASE_SECRET_KEY or SUPABASE_SERVICE_ROLE_KEY
# - APP_SESSION_SECRET
# - SESSION / IDEMPOTENCY / CRON secrets
# - TON_API_KEY / TONCENTER_API_KEY
# - TON_MINTER_PRIVATE_KEY / TON_MINTER_MNEMONIC or TON_MINT_PROVIDER_TOKEN
# Do not define any of these with a VITE_ prefix.

# API CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Telegram Bot / Telegram Mini App
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_BOT_USERNAME=replace_with_bot_username_without_at
TELEGRAM_MINI_APP_SHORT_NAME=replace_with_mini_app_short_name

# Telegram webhook
TELEGRAM_WEBHOOK_URL=http://localhost:3000/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Telegram initData 验证
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TELEGRAM_INIT_DATA_CLOCK_TOLERANCE_SECONDS=60

# Telegram deep link / referral payload
TELEGRAM_START_PARAM_SECRET=replace_with_random_start_param_secret
TELEGRAM_REFERRAL_PAYLOAD_TTL_SECONDS=2592000

# Telegram share
TELEGRAM_SHARE_TEXT=Join tmaGame and open your first blind box.
TELEGRAM_SHARE_URL=https://t.me/replace_with_bot_username/replace_with_mini_app_short_name

# -----------------------------------------------------------------------------
# Telegram Stars Payment
# -----------------------------------------------------------------------------
# Telegram Stars 数字商品支付使用 XTR。
TELEGRAM_STARS_CURRENCY=XTR

# Stars 支付通常不需要第三方 provider token。
# 如果你的 Bot API 封装要求传 provider_token，可在服务端按 Bot API 规则处理空字符串。
TELEGRAM_STARS_PROVIDER_TOKEN=

# 开盒订单支付有效期
STARS_OPEN_ORDER_EXPIRES_MINUTES=15
PAYMENT_WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400

# 支付发货补偿脚本
PAYMENT_RETRY_LIMIT=10
PAYMENT_RETRY_DRY_RUN=true
SYSTEM_ADMIN_USER_ID=

# 支付客服 / 退款 / 争议处理入口
PAYMENT_SUPPORT_URL=https://t.me/replace_with_support_username
PAYMENT_SUPPORT_EMAIL=support@example.com

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
# 新版 Supabase 推荐使用 sb_secret_xxx；旧项目可继续使用 service role。
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret

# Supabase project
SUPABASE_PROJECT_REF=replace_with_project_ref
SUPABASE_ACCESS_TOKEN=replace_with_supabase_access_token

# Database URLs
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DIRECT_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Database schemas
SUPABASE_DB_SCHEMAS=core,economy,catalog,gacha,inventory,market,payments,tasks,album,onchain,ops

# Supabase Storage
SUPABASE_STORAGE_PUBLIC_URL=http://127.0.0.1:54321/storage/v1/object/public
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS=3600

# 浏览器可见 Supabase 配置仅在你允许前端读公开 view 或 Realtime 时启用。
# 第一阶段核心写操作仍必须走 Vercel API -> Supabase RPC。
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_or_publishable_key

# -----------------------------------------------------------------------------
# App Session / Security
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=tma_game_session
APP_SESSION_SECRET=replace_with_64_char_random_session_secret
SESSION_TTL_SECONDS=86400
SESSION_REFRESH_THRESHOLD_SECONDS=86400
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

ADMIN_SESSION_COOKIE_NAME=tma_game_admin_session
ADMIN_SESSION_SECRET=replace_with_64_char_random_admin_session_secret
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_SESSION_SECURE_COOKIE=false
ADMIN_SESSION_SAME_SITE=lax

# 用于加密敏感字段，例如钱包 proof challenge、外部 payload、风控数据。
# 建议使用 32 bytes base64。
ENCRYPTION_KEY=replace_with_32_bytes_base64_key

# 幂等、防重复点击、防重复 webhook
IDEMPOTENCY_SECRET=replace_with_random_idempotency_secret
IDEMPOTENCY_TTL_SECONDS=86400

# Cron 任务鉴权
CRON_SECRET=replace_with_random_cron_secret

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_STRICT_MAX_REQUESTS=30

# 可选：使用 Upstash Redis 做分布式限流
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Game Economy
# -----------------------------------------------------------------------------
# 开盒支付 Stars 后返还 100 K-coin
OPEN_BOX_REWARD_KCOIN=100

# 十连抽价格倍率；9000 bps = 9 折
TEN_DRAW_PRICE_BPS=9000

# 市场手续费；500 bps = 5%
MARKET_FEE_BPS=500

# 邀请奖励：被邀请人完成首次开盒后，双方各得 500 K-coin
REFERRAL_FIRST_OPEN_REWARD_KCOIN=500

# 邀请人获得好友开盒收益 10% 分红；1000 bps = 10%
REFERRAL_COMMISSION_BPS=1000

# 合成默认失败返还策略：返还等级最高的主藏品
EVOLUTION_FAILURE_RETURN_POLICY=highest_level_item

# 分解奖励是否允许分解最后一份藏品
DECOMPOSE_ALLOW_LAST_COPY=false

# -----------------------------------------------------------------------------
# Gacha / Blind Box
# -----------------------------------------------------------------------------
GACHA_ORDER_MAX_DRAWS_PER_ORDER=10
GACHA_DEFAULT_SINGLE_DRAW_COUNT=1
GACHA_DEFAULT_TEN_DRAW_COUNT=10
GACHA_RESULT_VISIBLE_TTL_SECONDS=86400
GACHA_RANDOM_AUDIT_ENABLED=true
DRAW_RANDOM_SECRET=replace_with_64_char_random_draw_audit_secret
DEV_GACHA_PAYMENT_MODE=true

# -----------------------------------------------------------------------------
# Market
# -----------------------------------------------------------------------------
MARKET_LISTING_MIN_PRICE_KCOIN=1
MARKET_LISTING_MAX_PRICE_KCOIN=999999999
MARKET_LISTING_DEFAULT_EXPIRES_DAYS=30
MARKET_MAX_ACTIVE_LISTINGS_PER_USER=100
MARKET_PRICE_HEALTH_LOW_BPS=7000
MARKET_PRICE_HEALTH_HIGH_BPS=13000

# -----------------------------------------------------------------------------
# Tasks / Referral / Sign-in
# -----------------------------------------------------------------------------
TASK_DAILY_RESET_TIME_UTC=00:00
SIGNIN_CAMPAIGN_LENGTH_DAYS=7
REFERRAL_BIND_TTL_DAYS=30
REFERRAL_REQUIRE_INVITEE_FIRST_OPEN=true
REFERRAL_COMMISSION_ENABLED=true

# -----------------------------------------------------------------------------
# Album / Leaderboard
# -----------------------------------------------------------------------------
ALBUM_LEADERBOARD_ENABLED=true
ALBUM_LEADERBOARD_PERIOD=weekly
ALBUM_LEADERBOARD_REFRESH_CRON=0 */6 * * *
ALBUM_MILESTONE_REWARD_ENABLED=true

# -----------------------------------------------------------------------------
# TON / TON Connect
# -----------------------------------------------------------------------------
TON_NETWORK=testnet
TON_API_BASE_URL=https://testnet.tonapi.io
TON_API_KEY=replace_with_tonapi_key
TONCENTER_API_KEY=replace_with_toncenter_api_key

# TON Connect
TONCONNECT_MANIFEST_URL=http://localhost:5173/tonconnect-manifest.json
TON_PROOF_TTL_SECONDS=300
TON_PROOF_CHALLENGE_BYTES=32

# TON NFT Collection
TON_COLLECTION_ADDRESS=
TON_NFT_COLLECTION_OWNER_ADDRESS=
TON_MINTER_WALLET_ADDRESS=

# 服务端 Mint 使用的敏感私钥。生产环境必须放 Vercel Secret。
TON_MINTER_PRIVATE_KEY=replace_with_server_side_minter_private_key
TON_MINTER_MNEMONIC=

# 折中 provider adapter。使用外部服务提交真实 Collection Mint 时配置，
# token 只能放服务端 / Vercel Secret，不能进入前端。
TON_MINT_PROVIDER_URL=
TON_NFT_MINT_PROVIDER_URL=
TON_TRANSACTION_PROVIDER_URL=
TON_NFT_TX_PROVIDER_URL=
TON_MINT_PROVIDER_TOKEN=
TON_NFT_PROVIDER_TOKEN=
TON_NFT_PROVIDER_NAME=
TON_MINT_PROVIDER_TIMEOUT_MS=15000

# Mint 队列
TON_MINT_ENABLED=false
TON_MINT_BATCH_SIZE=10
TON_TX_SYNC_BATCH_SIZE=20
TON_MINT_MAX_RETRIES=5
TON_MINT_RETRY_DELAY_SECONDS=60
TON_MINT_CONFIRMATION_TIMEOUT_SECONDS=300

# NFT metadata
NFT_METADATA_BASE_URL=http://localhost:5173/nft-metadata
NFT_COLLECTION_METADATA_URI=http://localhost:5173/nft-metadata/collection.json
NFT_ITEM_METADATA_BASE_URI=http://localhost:5173/nft-metadata/items

# Royalty；0 表示先不启用版税
NFT_ROYALTY_FACTOR=0
NFT_ROYALTY_BASE=1000
NFT_ROYALTY_ADDRESS=

# Wallet sync
WALLET_SYNC_ENABLED=true
WALLET_SYNC_BATCH_SIZE=50
WALLET_SYNC_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_ENABLED=true

# 一次性 bootstrap 超级管理员使用的 Telegram user id 白名单。
# 格式：正整数，多个用英文逗号分隔；示例：123456789,987654321。
# 只给 scripts/create-admin.ts 使用，不是运行时权限来源。
# 完成 bootstrap 后，后台权限以后端 requireAdmin 查询 ops.admin_users 为准。
# 生产 / Preview 环境请在 Vercel Environment Variables 中配置真实值；
# 不要把真实 Telegram user id 提交到仓库。
ADMIN_BOOTSTRAP_TELEGRAM_USER_IDS=

# 后台危险操作二次确认
ADMIN_REQUIRE_DANGER_CONFIRMATION=true
ADMIN_AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# These FEATURE_* values are server/bootstrap defaults only. Sensitive values
# must still stay in server env variables above, and runtime switches should be
# mirrored in ops.feature_flags for admin-controlled emergency pause.
FEATURE_GACHA_ENABLED=true
FEATURE_MARKET_ENABLED=true
FEATURE_COLLECTION_UPGRADE_ENABLED=true
FEATURE_COLLECTION_EVOLVE_ENABLED=true
FEATURE_COLLECTION_DECOMPOSE_ENABLED=true
FEATURE_ALBUM_ENABLED=true
FEATURE_TASKS_ENABLED=true
FEATURE_REFERRAL_ENABLED=true
FEATURE_WALLET_ENABLED=true
FEATURE_STARS_PAYMENT_ENABLED=false
FEATURE_PAYMENT_WEBHOOK_FULFILLMENT_ENABLED=false
FEATURE_WALLET_PROOF_ENABLED=true
FEATURE_WALLET_SYNC_ENABLED=true
FEATURE_TON_MINT_ENABLED=false
FEATURE_MINT_WORKER_ENABLED=false
FEATURE_ADMIN_PAYMENT_OPS_ENABLED=false
FEATURE_GAME_PLACEHOLDER_ENABLED=true

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1

# 可选：外部日志服务
LOGTAIL_SOURCE_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=tma-game

# -----------------------------------------------------------------------------
# Local Test
# -----------------------------------------------------------------------------
TEST_TELEGRAM_USER_ID=100000001
TEST_TELEGRAM_USERNAME=test_user
TEST_TON_WALLET_ADDRESS=
TEST_SKIP_PAYMENT_WEBHOOK_SIGNATURE=false
TEST_FORCE_GACHA_RESULT_TEMPLATE_ID=
TEST_FORCE_EVOLUTION_SUCCESS=
