# PokePets 全量重构后的唯一环境变量清单。真实值只能进入平台 Secret。
# 浏览器不接收业务规则、数据库凭据、Bot Token 或任何私钥。

# Web public runtime
# Web 固定使用同源 API 与 /tonconnect-manifest.json，不读取 VITE_* 环境变量。

# Server runtime
APP_ENV=development
APP_BASE_URL=http://localhost:3000
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_secret
REFERRAL_CODE_SECRET=replace_with_at_least_32_random_characters
CRON_SECRET=replace_with_at_least_32_random_characters

# Telegram Mini App / Bot / Stars
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_BOT_USERNAME=replace_without_at
TELEGRAM_MINI_APP_SHORT_NAME=replace_with_short_name
TELEGRAM_WEBHOOK_SECRET=replace_with_at_least_16_random_characters
PAYMENT_SUPPORT_URL=https://t.me/replace_with_support_account

# TON server runtime
TON_NETWORK=testnet
TON_API_BASE_URL=https://testnet.toncenter.com/api/v2
TON_API_KEY=replace_with_api_key
TON_COLLECTION_ADDRESS=replace_after_contract_deployment
TON_MINT_VALUE_NANO=50000000
TON_MINT_AUTH_PRIVATE_KEY=replace_with_64_byte_ed25519_private_key_hex
NFT_METADATA_BASE_URL=https://app.example/api/nft-metadata

# TON deployment command; never expose these values to the browser.
TON_RPC_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_RPC_API_KEY=replace_with_rpc_api_key
TON_DEPLOYER_MNEMONIC=replace_with_deployment_wallet_mnemonic
TON_COLLECTION_OWNER_ADDRESS=replace_with_owner_address
TON_ROYALTY_DESTINATION=replace_with_royalty_address
TON_MINT_AUTH_PUBLIC_KEY_HEX=replace_with_32_byte_ed25519_public_key_hex
TON_COLLECTION_METADATA_URL=https://immutable-metadata.example/pokepets/collection.json
TON_COLLECTION_DEPLOY_VALUE_NANO=100000000
# Mainnet additionally requires: TON_MAINNET_DEPLOY_APPROVED=I_UNDERSTAND_MAINNET
