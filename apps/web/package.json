{
  "name": "@tma-game/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram Mini App frontend for blind-box card game.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:https": "cross-env VITE_USE_HTTPS=true vite --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"*.{ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','coverage','.vite','node_modules/.cache']) fs.rmSync(p,{recursive:true,force:true});\""
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.11",
    "@tma.js/sdk": "3.2.0",
    "@tma.js/sdk-react": "3.0.19",
    "@tonconnect/ui-react": "2.4.4",
    "@tma-game/api-client": "workspace:*",
    "@tma-game/config": "workspace:*",
    "@tma-game/domain": "workspace:*",
    "@tma-game/ui": "workspace:*",
    "@tma-game/validation": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.2.1",
    "lucide-react": "1.16.0",
    "motion": "12.39.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.1",
    "tailwind-merge": "3.6.0",
    "uuid": "14.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.7",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cross-env": "10.1.0",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-mkcert": "2.0.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 safari version",
      "last 1 firefox version"
    ]
  }
}
