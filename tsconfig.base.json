{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "tmaGame Base TypeScript Config",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@web/*": ["apps/web/src/*"],
      "@admin/*": ["apps/admin/src/*"],
      "@api/*": ["api/*"],
      "@tma-game/api-client": ["packages/api-client/src/index.ts"],
      "@tma-game/config": ["packages/config/src/index.ts"],
      "@tma-game/db-types": ["packages/db-types/src/index.ts"],
      "@tma-game/domain": ["packages/domain/src/index.ts"],
      "@tma-game/server": ["packages/server/src/index.ts"],
      "@tma-game/ui": ["packages/ui/src/index.ts"],
      "@tma-game/validation": ["packages/validation/src/index.ts"],
      "@domain/*": ["packages/domain/src/*"],
      "@validation/*": ["packages/validation/src/*"],
      "@api-client/*": ["packages/api-client/src/*"],
      "@server/*": ["packages/server/src/*"],
      "@db-types/*": ["packages/db-types/src/*"],
      "@ui/*": ["packages/ui/src/*"],
      "@config/*": ["packages/config/src/*"],
      "@scripts/*": ["scripts/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".vercel",
    "coverage",
    "playwright-report",
    "test-results",
    "supabase/.branches",
    "supabase/.temp",
    "supabase/.shadow",
    "contracts/dist"
  ]
}
